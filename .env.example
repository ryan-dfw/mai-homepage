# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Firebase (Firestore) — used to sync Thi's copy/image edits across visitors.
# Leave these blank to run with localStorage-only editing (no cross-device sync).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary — used for unsigned image uploads (hero/about/gallery photos).
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
